{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "VITE_API_URL": "@bloodwing_api_url",
    "VITE_FIREBASE_API_KEY": "@firebase_api_key",
    "VITE_FIREBASE_PROJECT_ID": "@firebase_project_id"
  }
}
